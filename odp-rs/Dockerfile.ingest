FROM rust:1.88-bookworm AS builder
WORKDIR /app
COPY Cargo.toml Cargo.lock* ./
COPY crates ./crates
RUN cargo build --release -p odp-ingest

FROM debian:bookworm-slim
# curl is required for the docker-compose healthcheck (curl -f localhost:8040/health).
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/odp-ingest /usr/local/bin/odp-ingest
EXPOSE 8040
CMD ["odp-ingest"]